{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PCStatsMonitor",
  "version": "0.1.0",
  "identifier": "com.pcmonitor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PC Monitor",
        "width": 350,
        "height": 500,
        "minWidth": 220,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "shadow": true,
        "skipTaskbar": false,
        "center": false,
        "x": 20,
        "y": 20
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
